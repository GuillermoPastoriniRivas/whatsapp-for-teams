# MongoDB
MONGODB_URI=mongodb://localhost:27017/whatsapp-teams

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Meta Cloud API
META_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# App
PORT=3000
FRONTEND_URL=http://localhost:3001

# Platform AI (single provider/model/key for ALL tenant bots)
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8
AI_API_KEY=sk-ant-...

# AWS SES (optional — falls back to IAM role if omitted)
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=no-reply@asis.chat
SES_REPLY_TO_EMAIL=contact@asis.chat

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:tu-email@dominio.com
