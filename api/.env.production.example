# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/hivvo?retryWrites=true&w=majority

# JWT
JWT_SECRET=generate-a-strong-secret-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=generate-another-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

# Meta Cloud API
META_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# App
PORT=3000
FRONTEND_URL=https://asis.chat

# AWS SES (uses IAM instance role on EC2 — no keys needed)
AWS_SES_REGION=us-east-1
SES_FROM_EMAIL=no-reply@asis.chat
SES_REPLY_TO_EMAIL=contact@asis.chat
