# MongoDB
MONGODB_URI=mongodb://localhost:27017/whatsapp-teams

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Meta Cloud API (global defaults — credentials are per phone number via providerConfig)
META_API_VERSION=v21.0

# App
PORT=3000
